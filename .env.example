APP_NAME=production-rag-assistant
ENV=local
LOG_LEVEL=INFO
API_KEYS=dev-key

POSTGRES_USER=rag
POSTGRES_PASSWORD=rag
POSTGRES_DB=rag
POSTGRES_PORT=5432
API_PORT=8000

DATABASE_URL=postgresql+asyncpg://rag:rag@localhost:5432/rag
SYNC_DATABASE_URL=postgresql+psycopg://rag:rag@localhost:5432/rag

EMBEDDING_PROVIDER=fake
EMBEDDING_MODEL=fake-embedding
EMBEDDING_DIMENSION=1536

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_TIMEOUT_SECONDS=30
OPENAI_MAX_RETRIES=2
OPENAI_RETRY_DELAY_SECONDS=0.25
OPENAI_MAX_OUTPUT_TOKENS=512

CORS_ALLOWED_ORIGINS=
CORS_ALLOWED_ORIGIN_REGEX=
CORS_ALLOW_CREDENTIALS=false

RATE_LIMIT_ENABLED=false
RATE_LIMIT_REQUESTS=60
RATE_LIMIT_WINDOW_SECONDS=60
RATE_LIMIT_EXCLUDED_PATHS=/health,/metrics,/app,/openapi.json,/docs,/redoc

RERANKER_PROVIDER=none
RERANK_TOP_N=5
VECTOR_TOP_K=20
SPARSE_TOP_K=20
FUSED_TOP_K=20
RRF_K=60

GENERATOR_PROVIDER=fake
LLM_MODEL=fake-llm

REFUSAL_SCORE_THRESHOLD=0.01
