      "targets": [
        {
          "expr": "sum by (provider, operation, category) (rate(rag_provider_errors_total[5m]))",
          "legendFormat": "{{provider}} {{operation}} {{category}}"
        }
      ],
      "title": "Provider error rate",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "s"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 8
      },
      "id": 4,
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum by (le, provider, operation, model) (rate(rag_provider_latency_seconds_bucket[5m])))",
          "legendFormat": "{{provider}} {{operation}} {{model}} p95"
        }
      ],
      "title": "Provider p95 latency",
      "type": "timeseries"
    },
    {
      "datasource": {
        "type": "prometheus",
        "uid": "${DS_PROMETHEUS}"
      },
      "fieldConfig": {
        "defaults": {
          "unit": "tps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 16
      },
      "id": 5,
      "targets": [
        {
          "expr": "sum by (provider, model, token_type) (rate(rag_provider_tokens_total[5m]))",
          "legendFormat": "{{provider}} {{model}} {{token_type}}"
